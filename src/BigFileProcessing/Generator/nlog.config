<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Info"
      internalLogFile="c:\temp\internal-nlog-generator.txt">

  <extensions>
    <add assembly="NLog.Extensions.Logging"/>
  </extensions>

  <targets>

    <target name="RowDataParserError" xsi:type="File"
        fileName="${basedir}/logs/${date:format=yyyy-MM-dd}/row.data.parser.error.log"
        layout="${longdate} - ${level}:${message}${onexception:${newline}${exception:maxInnerExceptionLevel=10:format=message,stacktrace:separator=${newline}:innerExceptionSeparator=&#xD;&#xA;&#x9;}}"/>

    <target name="FileGeneratorServiceError" xsi:type="File"
            fileName="${basedir}/logs/${date:format=yyyy-MM-dd}/file.generator.service.error.log"
            layout="${longdate} - ${level}:${message}${onexception:${newline}${exception:maxInnerExceptionLevel=10:format=message,stacktrace:separator=${newline}:innerExceptionSeparator=&#xD;&#xA;&#x9;}}"/>

    <target name="FileGeneratorServiceTrace" xsi:type="File"
            fileName="${basedir}/logs/${date:format=yyyy-MM-dd}/file.generator.service.trace.log"
            layout="${longdate} - ${level}:${message}"/>
    
  </targets>

  <rules>
    
    <logger name="BusinessLogic.Services.Implementations.RowDataParser"
                  minlevel="Error" maxlevel="Fatal" writeTo="RowDataParserError" />

    <logger name="BusinessLogic.Services.Implementations.FileGeneratorService"
                  minlevel="Trace" maxlevel="Warning" writeTo="FileGeneratorServiceTrace" />

    <logger name="BusinessLogic.Services.Implementations.FileGeneratorService"
                  minlevel="Error" maxlevel="Fatal" writeTo="FileGeneratorServiceError" />
    
  </rules>
</nlog>
