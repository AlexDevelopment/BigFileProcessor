{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Generator": {
    "Folder": "c:\\temp",
    "MaxFileSize": 100, //1073741824 //10737418240
    "Numbers": [
      1,
      22,
      333,
      44,
      5,
      66,
      777,
      88,
      9,
      10
    ],
    "Strings": [
      "qwerty",
      "asdfgh",
      "zxcvbn"
    ]
  }
}
